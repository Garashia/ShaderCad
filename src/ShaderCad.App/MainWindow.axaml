<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:ShaderCad.App.Views"
        xmlns:renderer="using:ShaderCad.Renderer.Controls"
        x:Class="ShaderCad.App.MainWindow"
        Title="ShaderCad"
        Width="1280" Height="720"
        Background="#1E1E1E">

    <Grid ColumnDefinitions="*,300">
        <!-- 左側：OpenGL ビューポート（イベントは上のオーバーレイが担当） -->
        <renderer:SilkViewportControl x:Name="ViewportControl"
                                      Grid.Column="0" />

        <!-- ★ 透明オーバーレイ: OpenGlControlBase がイベントをブロックするため
             その上に透明な Border を重ねてマウスを確実に捕捉する -->
        <Border x:Name="ViewportOverlay"
                Grid.Column="0"
                Background="Transparent"
                Cursor="Cross" />

        <!-- 右側：Inspector領域 -->
        <views:InspectorView Grid.Column="1" x:Name="InspectorViewControl" />
    </Grid>

</Window>
